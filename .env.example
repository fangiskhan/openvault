# ---- Database ----
# Local (default): zero-setup SQLite. The DB file is created on `prisma db push`.
DATABASE_URL="file:./dev.db"
#
# Production / Vercel: use Postgres (Supabase, Neon, or Vercel Postgres).
# 1) In prisma/schema.prisma set: provider = "postgresql"
# 2) Set DATABASE_URL to your Postgres connection string, e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/openvault?sslmode=require"

# ---- Auth (single-user self-host) ----
# APP_PASSWORD gates access. Empty = no gate (fine for purely local use).
# ALWAYS set a strong password + secret before exposing the server.
APP_PASSWORD=""
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- MCP (agents) ----
# Bearer token AI agents present to /api/mcp. Empty = open (local only).
# Connect from Claude Code:
#   claude mcp add --transport http openvault http://localhost:3000/api/mcp \
#     --header "Authorization: Bearer <MCP_TOKEN>"
MCP_TOKEN=""

# ---- File storage ----
# "local" -> uploads saved to ./storage (good for self-host / your own PC)
# "vercel" -> Vercel Blob (required on Vercel; no persistent disk there)
STORAGE_DRIVER="local"
# BLOB_READ_WRITE_TOKEN=""
