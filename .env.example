# ---- Database ----
# Local (default): zero-setup SQLite. The DB file is created on `prisma db push`.
DATABASE_URL="file:./dev.db"
#
# Production / Vercel: use Postgres (Supabase, Neon, or Vercel Postgres).
# 1) In prisma/schema.prisma set: provider = "postgresql"
# 2) Set DATABASE_URL to your Postgres connection string, e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/openvault?sslmode=require"

# ---- Auth (single-user self-host) ----
# APP_PASSWORD gates access. Empty = no gate (fine for purely local use).
# AUTH_SECRET signs the session cookie; change it from the placeholder below.
# In production the server REFUSES TO START if APP_PASSWORD is empty or
# AUTH_SECRET is still a placeholder (set OPENVAULT_PUBLIC=1 to override).
APP_PASSWORD=""
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- MCP (agents) ----
# Bearer token AI agents present to /api/mcp. Empty = open (local only).
# In production an empty token refuses to start (or the route returns 503),
# since it would leave the agent write endpoint open (set OPENVAULT_PUBLIC=1
# to override). Connect from Claude Code:
#   claude mcp add --transport http openvault http://localhost:6900/api/mcp \
#     --header "Authorization: Bearer <MCP_TOKEN>"
MCP_TOKEN=""

# ---- Open-mode override ----
# By default a production build (NODE_ENV=production) won't start with empty/
# placeholder auth secrets, so an exposed server can't accidentally run open.
# Set OPENVAULT_PUBLIC=1 to ALLOW running with open gates on purpose (e.g. a
# trusted private LAN or a deliberately public read demo). Leave it unset
# everywhere else. Local `npm run dev` is never affected.
# OPENVAULT_PUBLIC="1"

# ---- File storage ----
# "local" -> uploads saved to ./storage (good for self-host / your own PC)
# "vercel" -> Vercel Blob (required on Vercel; no persistent disk there)
STORAGE_DRIVER="local"
# BLOB_READ_WRITE_TOKEN=""
